<?xml version="1.0" encoding="UTF-8"?>

<!--
    ============================================================
    分类管理对话框 (CategoryManagerDialog)
    ============================================================
-->

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.changjiang.keystore.ui.controller.CategoryManagerController"
      spacing="12" styleClass="form-panel" minWidth="420" minHeight="320"
      stylesheets="@../css/style.css">

    <Label text="分类管理" styleClass="label-title"/>

    <TableView fx:id="categoryTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="分类名称" prefWidth="220"/>
            <TableColumn fx:id="accountCountColumn" text="账户数量" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <TextField fx:id="newCategoryField" promptText="新分类名称" HBox.hgrow="ALWAYS"/>
        <Button text="新增" onAction="#onAddCategory" styleClass="btn-primary"/>
    </HBox>

    <HBox alignment="CENTER_RIGHT" styleClass="dialog-footer">
        <Button text="关闭" onAction="#onClose" styleClass="btn-danger form-action-btn"/>
    </HBox>
</VBox>
