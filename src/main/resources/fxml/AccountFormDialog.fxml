<?xml version="1.0" encoding="UTF-8"?>

<!--
    ============================================================
    账户表单对话框 (AccountFormDialog)
    ============================================================
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane xmlns="http://javafx.com/javafx/17"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.changjiang.keystore.ui.controller.AccountFormController"
          hgap="14" vgap="12" styleClass="form-panel"
          stylesheets="@../css/style.css">

    <columnConstraints>
        <ColumnConstraints hgrow="NEVER" minWidth="88"/>
        <ColumnConstraints hgrow="ALWAYS" minWidth="280"/>
    </columnConstraints>

    <Label fx:id="titleLabel" text="账户信息" styleClass="label-title"
           GridPane.columnSpan="2" GridPane.rowIndex="0"/>

    <Label text="分类" styleClass="label-subtitle" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <ComboBox fx:id="categoryComboBox" promptText="请选择分类"
              GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity"/>

    <Label text="名称" styleClass="label-subtitle" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextField fx:id="nameField" promptText="输入账户名称"
               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <Label text="地址" styleClass="label-subtitle" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <TextField fx:id="addressField" promptText="URL / IP / 楼号等"
               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    <Label text="端口" styleClass="label-subtitle" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
    <TextField fx:id="portField" promptText="端口号（可选）"
               GridPane.rowIndex="4" GridPane.columnIndex="1"/>

    <Label text="账号" styleClass="label-subtitle" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
    <TextField fx:id="usernameField" promptText="登录账号"
               GridPane.rowIndex="5" GridPane.columnIndex="1"/>

    <Label text="密码" styleClass="label-subtitle" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
    <StackPane GridPane.rowIndex="6" GridPane.columnIndex="1">
        <PasswordField fx:id="passwordField" promptText="密码"/>
        <TextField fx:id="passwordVisibleField" visible="false"/>
        <CheckBox fx:id="showPasswordCheckBox" text="显示" layoutX="200" layoutY="8"/>
    </StackPane>

    <Label text="有效期从" styleClass="label-subtitle" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
    <DatePicker fx:id="validFromPicker" promptText="可选"
                GridPane.rowIndex="7" GridPane.columnIndex="1" maxWidth="Infinity"/>

    <Label text="有效期至" styleClass="label-subtitle" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
    <DatePicker fx:id="validToPicker" promptText="可选"
                GridPane.rowIndex="8" GridPane.columnIndex="1" maxWidth="Infinity"/>

    <Label text="备注" styleClass="label-subtitle" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
    <TextArea fx:id="notesArea" promptText="备注信息（可选）" prefRowCount="3"
              wrapText="true" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

    <!-- 底部仅保留保存 / 关闭 -->
    <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="dialog-footer"
          GridPane.rowIndex="10" GridPane.columnIndex="0" GridPane.columnSpan="2">
        <Button text="保存" onAction="#onSave" styleClass="btn-primary form-action-btn"/>
        <Button text="关闭" onAction="#onCancel" styleClass="btn-danger form-action-btn"/>
    </HBox>
</GridPane>
