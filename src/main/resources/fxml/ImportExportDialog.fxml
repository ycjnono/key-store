<?xml version="1.0" encoding="UTF-8"?>

<!--
    ============================================================
    导入导出对话框 (ImportExportDialog)
    ============================================================
-->

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.changjiang.keystore.ui.controller.ImportExportController"
      spacing="0" styleClass="form-panel"
      stylesheets="@../css/style.css">

    <TabPane tabClosingPolicy="UNAVAILABLE" minWidth="480" minHeight="380" VBox.vgrow="ALWAYS">

        <Tab text="导出" fx:id="exportTab">
            <VBox spacing="12" style="-fx-padding: 16;">
                <Label text="选择导出范围" styleClass="label-section"/>
                <ComboBox fx:id="exportScopeComboBox" prefWidth="320" maxWidth="Infinity"/>

                <ListView fx:id="exportCategoryList" visible="false" prefHeight="120"/>

                <HBox spacing="8">
                    <TextField fx:id="exportPathField" promptText="导出文件路径"
                               HBox.hgrow="ALWAYS" editable="false"/>
                    <Button text="浏览" onAction="#onChooseExportPath" styleClass="btn-secondary"/>
                </HBox>

                <Button text="导出" onAction="#onExport" styleClass="btn-primary" maxWidth="120"/>
                <Label fx:id="exportStatusLabel" styleClass="label-subtitle"/>
            </VBox>
        </Tab>

        <Tab text="导入" fx:id="importTab">
            <VBox spacing="12" style="-fx-padding: 16;">
                <Label text="选择导入文件" styleClass="label-section"/>
                <HBox spacing="8">
                    <TextField fx:id="importPathField" promptText="选择导入文件"
                               HBox.hgrow="ALWAYS" editable="false"/>
                    <Button text="浏览" onAction="#onChooseImportFile" styleClass="btn-secondary"/>
                </HBox>

                <Label text="导入模式" styleClass="label-section"/>
                <ComboBox fx:id="importModeComboBox" prefWidth="320" maxWidth="Infinity"
                          onAction="#onImportModeChanged"/>

                <Button text="预览" onAction="#onImportModeChanged" styleClass="btn-secondary" maxWidth="100"/>
                <Label fx:id="importPreviewLabel" text="选择文件后点击预览查看导入结果"
                       styleClass="label-subtitle" wrapText="true"/>

                <Button text="执行导入" onAction="#onImport" styleClass="btn-primary" maxWidth="120"/>
            </VBox>
        </Tab>
    </TabPane>

    <HBox alignment="CENTER_RIGHT" styleClass="dialog-footer" spacing="10">
        <Button text="关闭" onAction="#onClose" styleClass="btn-danger form-action-btn"/>
    </HBox>
</VBox>
