<?xml version="1.0" encoding="UTF-8"?>

<!--
    ============================================================
    主界面 (DashboardView)
    ============================================================
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.changjiang.keystore.ui.controller.DashboardController"
            stylesheets="@../css/style.css">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="toolbar">
            <Label text="🔑 Key-Store" styleClass="toolbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="锁定" onAction="#onLock" styleClass="btn-danger"/>
            <Button text="导入/导出" onAction="#onImportExport" styleClass="btn-secondary"/>
            <Button text="退出" onAction="#onExit" styleClass="btn-danger"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="8" styleClass="sidebar" minWidth="180" prefWidth="200">
            <Label text="分类" styleClass="label-section"/>
            <ListView fx:id="categoryListView" VBox.vgrow="ALWAYS"/>
            <Button text="分类管理" onAction="#onManageCategories" styleClass="btn-secondary" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="12" styleClass="content-panel">
            <HBox spacing="10">
                <Label text="搜索" styleClass="label-section"/>
                <TextField fx:id="searchField" promptText="输入账户名称或账号..."
                           HBox.hgrow="ALWAYS"/>
            </HBox>

            <TableView fx:id="accountTableView" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameColumn" text="名称" prefWidth="200"/>
                    <TableColumn fx:id="addressColumn" text="地址" prefWidth="250"/>
                    <TableColumn fx:id="usernameColumn" text="账号" prefWidth="150"/>
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="＋ 新增账户" onAction="#onAddAccount" styleClass="btn-primary"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusLabel" styleClass="status-label"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
