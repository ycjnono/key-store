<?xml version="1.0" encoding="UTF-8"?>
<!--
    ============================================================
    Logback 日志配置
    ============================================================
    功能 : 配置日志输出
           开发环境: 输出到控制台 + 文件（按天滚动）
           生产环境: 可通过 -Dlogback.configurationFile 指定不同配置
    ============================================================
-->
<configuration>
    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 文件输出（按天滚动，保留 7 天） -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 日志文件路径: 工作目录/logs/keystore.log（开发环境即工程根目录） -->
        <file>${user.dir}/logs/keystore.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${user.dir}/logs/keystore.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
            <totalSizeCap>50MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 项目包日志：认证与加密流程 -->
    <logger name="com.changjiang.keystore" level="DEBUG"/>

    <!-- 全局日志级别: 开发环境 DEBUG，生产环境可改为 INFO -->
    <root level="DEBUG">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- 第三方库日志级别调高，减少噪音 -->
    <logger name="org.xerial" level="WARN"/>
    <logger name="com.fasterxml.jackson" level="WARN"/>
</configuration>
