# 构建输出（release 安装包需纳入版本库，见下方例外规则）
node_modules/
release/*
!release/KeyStore-*-Setup.exe
!release/KeyStore-*-Setup.exe.blockmap
dist/
.dist-stale-*/
release-stale-*/
dist-stale-*/

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/

# 本地数据与日志（含用户密码库，禁止提交）
data/
logs/

# 系统文件
.DS_Store
Thumbs.db
*.log

# 打包临时文件（release 安装包除外，见上方 ! 规则）
*.exe
!release/KeyStore-*-Setup.exe
*.msi
dist/
.dist-stale-*/

# Python
__pycache__/
*.pyc
